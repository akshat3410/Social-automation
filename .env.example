# ==========================================================================
# Social Engine configuration
#
# Quick start: cp .env.example .env, set SECRET_KEY and AI_API_KEY,
# then run: docker compose up -d
#
# NOTE for docker compose users: DATABASE_URL and REDIS_URL are overridden
# by docker-compose.yml to point at the postgres/redis services, so the
# localhost defaults below only matter when running the backend directly
# on your machine (scripts/setup_dev.sh).
# ==========================================================================

# --- App -------------------------------------------------------------------
# Never run production with DEBUG=True.
DEBUG=False
# REQUIRED. Signs JWTs. Generate one with: openssl rand -hex 32
SECRET_KEY=change-me-generate-with-openssl-rand-hex-32
# Comma-separated list of allowed browser origins.
CORS_ORIGINS=http://localhost:3000
API_V1_STR=/api/v1
# Access token lifetime in minutes (default: 1 day).
ACCESS_TOKEN_EXPIRE_MINUTES=1440
# Optional: separate Fernet key for encrypting stored social tokens
# (falls back to a key derived from SECRET_KEY). Generate with:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
#ENCRYPTION_KEY=

# --- Database --------------------------------------------------------------
# Used when running the backend locally; docker compose overrides this.
DATABASE_URL=postgresql+asyncpg://social_user:social_password@localhost:5432/social_engine
# Credentials for the docker compose postgres service (must match DATABASE_URL).
POSTGRES_USER=social_user
POSTGRES_PASSWORD=social_password
POSTGRES_DB=social_engine

# --- Redis -----------------------------------------------------------------
# Used when running the backend locally; docker compose overrides this.
REDIS_URL=redis://localhost:6379/0

# --- AI / LLM (OpenAI-compatible; OpenRouter by default) -------------------
AI_BASE_URL=https://openrouter.ai/api/v1
# REQUIRED. Your OpenRouter (or other OpenAI-compatible) API key.
AI_API_KEY=sk-or-your-key-here
MODEL_RESEARCH=anthropic/claude-haiku-4.5
MODEL_WRITING=anthropic/claude-sonnet-4.5
MODEL_EDITING=anthropic/claude-haiku-4.5
LLM_TIMEOUT_SECONDS=60
# How many draft variations to generate per idea (1-5).
NUM_DRAFT_VARIATIONS=3

# --- Embeddings (optional; enables semantic memory + dedup) ---------------
# Any OpenAI-compatible embeddings endpoint. Leave EMBEDDINGS_API_KEY empty
# to disable memory features gracefully.
EMBEDDINGS_BASE_URL=https://api.openai.com/v1
#EMBEDDINGS_API_KEY=
EMBEDDINGS_MODEL=text-embedding-3-small

# --- Social platforms ------------------------------------------------------
# With both disabled, publishing runs in dry-run mode (posts are recorded
# in the DB but not sent anywhere) — useful for evaluating the pipeline.
ENABLE_TWITTER=False
#TWITTER_API_KEY=
#TWITTER_API_SECRET=
ENABLE_REDDIT=False
#REDDIT_CLIENT_ID=
#REDDIT_CLIENT_SECRET=

# --- Quality gate thresholds (0.0 - 1.0) ----------------------------------
MIN_ENGAGEMENT_SCORE=0.7
MAX_SPAM_SCORE=0.2
MIN_READABILITY_SCORE=0.5
MIN_BRAND_CONSISTENCY=0.8
MIN_HUMAN_SCORE=0.6
# When False, drafts that pass the quality gate are auto-approved.
ENABLE_HUMAN_APPROVAL=True

# --- Memory ----------------------------------------------------------------
# Cosine similarity above which content counts as a duplicate.
MEMORY_SIMILARITY_THRESHOLD=0.85

# --- Scheduling / retries --------------------------------------------------
SCHEDULER_POLL_INTERVAL_SECONDS=60
MAX_RETRIES=3
RETRY_DELAY_SECONDS=300

# --- Rate limiting (per client IP, per minute) -----------------------------
RATE_LIMIT_AUTH_PER_MINUTE=10
RATE_LIMIT_GENERATE_PER_MINUTE=5

# --- Frontend --------------------------------------------------------------
# Baked into the frontend at build time by docker compose.
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# --- Host port overrides for docker compose --------------------------------
#POSTGRES_PORT=5432
#BACKEND_PORT=8000
#FRONTEND_PORT=3000
