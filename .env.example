# ============================
# App Settings
# ============================
DEBUG=True
SECRET_KEY=super-secret-placeholder-key
CORS_ORIGINS=["http://localhost:3000"]
API_V1_STR=/api/v1

# ============================
# Database Settings
# ============================
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/social_engine

# ============================
# Redis Settings
# ============================
REDIS_URL=redis://localhost:6379/0

# ============================
# AI / LLM Settings
# ============================
AI_BASE_URL=https://openrouter.ai/api/v1
AI_API_KEY=sk-or-placeholder-key
MODEL_RESEARCH=anthropic/claude-3-opus-20240229
MODEL_WRITING=anthropic/claude-3-sonnet-20240229
MODEL_EDITING=anthropic/claude-3-haiku-20240307

# ============================
# Feature Flags
# ============================
ENABLE_TWITTER=True
ENABLE_REDDIT=False
ENABLE_HUMAN_APPROVAL=True

# ============================
# Social Provider Settings
# ============================
TWITTER_API_KEY=your_twitter_api_key
TWITTER_API_SECRET=your_twitter_api_secret
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret

# ============================
# Quality Gate Thresholds
# ============================
MIN_ENGAGEMENT_SCORE=0.7
MAX_SPAM_SCORE=0.2
MIN_READABILITY_SCORE=0.5
MIN_BRAND_CONSISTENCY=0.8

# ============================
# Scheduling
# ============================
MAX_RETRIES=3
RETRY_DELAY_SECONDS=300
